{
  "name": "serverless-api-gateway",
  "version": "1.0.0",
  "description": "Scalable serverless CRUD API with AWS SAM, TypeScript, DynamoDB, and rate-limiting",
  "main": "src/handlers",
  "scripts": {
    "build": "tsc",
    "sam-build": "sam build",
    "sam-local": "sam local start-api --env-vars sam-env.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "ts-node src/local-server.ts",
    "deploy": "sam build && sam deploy --guided"
  },
  "keywords": [
    "aws",
    "sam",
    "lambda",
    "dynamodb",
    "api-gateway",
    "serverless",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.0.0",
    "@aws-lambda-powertools/metrics": "^2.0.0",
    "@aws-lambda-powertools/tracer": "^2.0.0",
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "aws-sdk-client-mock": "^4.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
